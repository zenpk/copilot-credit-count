{
  "name": "copilot-credit-count",
  "displayName": "Copilot Credit Count",
  "description": "Track and visualize your GitHub Copilot credit usage across models with an interactive dashboard.",
  "version": "0.1.0",
  "publisher": "zenpk",
  "author": {
    "name": "zenpk"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenpk/copilot-credit-count"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "credits",
    "usage",
    "ai",
    "github copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotCredits.showDashboard",
        "title": "Copilot Credits: Show Dashboard"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
